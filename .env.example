# Copy this file to .env and fill in values before running docker compose.
# .env is gitignored — never commit real credentials.

# PostgreSQL source (Zone 1)
POSTGRES_SOURCE_USER=postgres
POSTGRES_SOURCE_PASSWORD=postgres

# PostgreSQL target (Zone 3)
POSTGRES_TARGET_USER=postgres
POSTGRES_TARGET_PASSWORD=postgres

# MinIO (Zone 4)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# CDC Reader
INITIAL_SNAPSHOT=false

# Orchestrator
K8S_NAMESPACE=cdc-pipeline
ALERT_WEBHOOK_URL=
HEALTH_POLL_INTERVAL=10s
LAG_POLL_INTERVAL=30s
DLQ_POLL_INTERVAL=60s

# Shared
LOG_LEVEL=info
